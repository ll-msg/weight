# 复制为 .env 后按需修改

# JWT 签名密钥（生产环境务必改成随机长字符串）
SECRET_KEY=change-me-to-a-random-secret-string

# Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 数据库连接串。默认本地 SQLite 单文件。
# 切换 PostgreSQL 示例： postgresql+psycopg://user:pass@localhost:5432/loseweight
DATABASE_URL=sqlite:///./app.db

# 允许跨域的前端地址
CORS_ORIGINS=http://localhost:3000
